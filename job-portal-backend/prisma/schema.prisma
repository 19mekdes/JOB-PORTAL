generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserType {
  id         Int      @id @default(autoincrement())
  type_name  String   @unique
  created_at DateTime @default(now())
  users      User[]
}

model User {
  id                         String                  @id @default(uuid())
  email                      String                  @unique
  password                   String
  user_type_id               Int
  is_active                  Boolean                 @default(true)
  last_login                 DateTime?
  full_name                  String?
  avatar                     String?
  created_at                 DateTime                @default(now())
  updated_at                 DateTime                @updatedAt
  reset_password_token       String?                 @unique
  reset_password_expires     DateTime?
  email_verified             Boolean                 @default(false)
  email_verification_token   String?
  email_verification_expires DateTime?
  AuditLog                   AuditLog[]
  employer_profile           EmployerProfile?
  seeker_profile             JobSeekerProfile?
  notifications              Notification[]
  notification_preference    NotificationPreference?
  search_logs                SearchLog[]
  user_type                  UserType                @relation(fields: [user_type_id], references: [id])
  
  @@index([email])
  @@index([user_type_id])
  @@index([reset_password_token])
}


// ===========================================

model SystemSetting {
  id                             Int      @id @default(autoincrement())
  site_name                      String   @default("JobPortal")
  site_description               String   @default("Connect job seekers with employers")
  site_logo                      String   @default("")
  site_favicon                   String   @default("")
  contact_email                  String   @default("admin@jobportal.com")
  support_email                  String   @default("support@jobportal.com")
  timezone                       String   @default("UTC")
  date_format                    String   @default("MM/DD/YYYY")
  maintenance_mode               Boolean  @default(false)
  maintenance_message            String   @default("")
  enable_registration            Boolean  @default(true)
  require_email_verification     Boolean  @default(true)
  default_user_role              String   @default("Job Seeker")
  max_users                      Int      @default(10000)
  auto_approve_employers         Boolean  @default(false)
  allow_social_login             Boolean  @default(false)
  require_job_approval           Boolean  @default(true)
  max_job_posts_per_employer     Int      @default(50)
  job_expiry_days                Int      @default(30)
  allow_job_editing              Boolean  @default(true)
  featured_job_price             Float    @default(49.99)
  allow_free_jobs                Boolean  @default(true)
  max_job_tags                   Int      @default(10)
  max_applications_per_seeker    Int      @default(100)
  require_cover_letter           Boolean  @default(false)
  require_resume_upload          Boolean  @default(true)
  application_cooldown           Int      @default(7)
  allow_withdraw_application     Boolean  @default(true)
  notify_employer_on_application Boolean  @default(true)
  password_min_length            Int      @default(8)
  require_uppercase              Boolean  @default(true)
  require_numbers                Boolean  @default(true)
  require_special_chars          Boolean  @default(false)
  session_timeout                Int      @default(30)
  max_login_attempts             Int      @default(5)
  two_factor_auth                Boolean  @default(false)
  lockout_duration               Int      @default(30)
  email_notifications            Boolean  @default(true)
  push_notifications             Boolean  @default(true)
  notify_on_new_job              Boolean  @default(true)
  notify_on_application          Boolean  @default(true)
  notify_on_status_change        Boolean  @default(true)
  weekly_digest                  Boolean  @default(true)
  admin_alert_emails             String   @default("")
  smtp_host                      String   @default("smtp.gmail.com")
  smtp_port                      Int      @default(587)
  smtp_user                      String   @default("")
  smtp_password                  String   @default("")
  smtp_encryption                String   @default("TLS")
  from_email                     String   @default("")
  from_name                      String   @default("")
  google_client_id               String   @default("")
  google_client_secret           String   @default("")
  linkedin_client_id             String   @default("")
  linkedin_client_secret         String   @default("")
  recaptcha_site_key             String   @default("")
  recaptcha_secret_key           String   @default("")
  auto_backup                    Boolean  @default(false)
  backup_frequency               String   @default("weekly")
  backup_retention               Int      @default(30)
  log_retention_days             Int      @default(90)
  allowed_file_types             String[] @default(["pdf", "doc", "docx", "txt"])
  max_file_size_mb               Int      @default(5)
  created_at                     DateTime @default(now())
  updated_at                     DateTime @updatedAt
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  admin_id    String
  action      String
  target_type String
  target_id   String
  details     Json?
  ip_address  String?
  created_at  DateTime @default(now())
  admin       User     @relation(fields: [admin_id], references: [id])
}

model JobSeekerProfile {
  id            String               @id @default(uuid())
  full_name     String
  phone         String?
  resume_url    String?
  skills        String[]
  experience    String?
  education     String?
  location      String?
  cover_image   String?
  avatar        String?
  bio           String?
  title         String?
  linkedin_url  String?
  github_url    String?
  portfolio_url String?
  availability  String?
  user_id       String               @unique
  applications  JobApplication[]
  bookmarks     JobBookmark[]
  preferences   JobSeekerPreference?
  user          User                 @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model JobSeekerPreference {
  id                     String           @id @default(uuid())
  seeker_id              String           @unique
  job_alerts_enabled     Boolean          @default(true)
  email_notifications    Boolean          @default(true)
  push_notifications     Boolean          @default(false)
  profile_visibility     String           @default("public")
  preferred_job_types    String[]         @default([])
  preferred_locations    String[]         @default([])
  preferred_industries   Int[]            @default([])
  min_salary             Int?
  max_salary             Int?
  experience_level       String           @default("entry")
  notification_frequency String           @default("instant")
  resume_visibility      Boolean          @default(true)
  allow_employer_contact Boolean          @default(true)
  created_at             DateTime         @default(now())
  updated_at             DateTime         @updatedAt
  seeker                 JobSeekerProfile @relation(fields: [seeker_id], references: [id], onDelete: Cascade)

  @@index([seeker_id])
}

model EmployerProfile {
  id                  String               @id @default(uuid())
  company_name        String
  company_description String?
  website             String?
  logo_url            String?
  industry_id         Int
  company_size        String?
  location            String?
  phone               String?
  founded_year        Int?
  headquarters        String?
  social_links        Json?
  jobs_count          Int                  @default(0)
  is_active           Boolean              @default(true)
  is_verified         Boolean              @default(false)
  cover_image         String?
  user_id             String               @unique
  created_at          DateTime             @default(now())
  updated_at          DateTime?
  industry            JobIndustry          @relation(fields: [industry_id], references: [id])
  user                User                 @relation(fields: [user_id], references: [id], onDelete: Cascade)
  notes               JobApplicationNote[]
  jobs                JobPost[]
  managed_companies   ManagedCompany[]

  @@index([user_id])
  @@index([industry_id])
}

model ManagedCompany {
  id           String          @id @default(uuid())
  employer_id  String
  company_name String
  logo_url     String?
  website      String?
  location     String?
  description  String?
  is_verified  Boolean         @default(false)
  created_at   DateTime        @default(now())
  updated_at   DateTime        @updatedAt
  jobs         JobPost[]
  employer     EmployerProfile @relation(fields: [employer_id], references: [id], onDelete: Cascade)

  @@index([employer_id])
  @@index([company_name])
}

model NotificationPreference {
  id                  Int      @id @default(autoincrement())
  user_id             String   @unique
  email_notifications Boolean  @default(true)
  push_notifications  Boolean  @default(true)
  application_updates Boolean  @default(true)
  new_job_alerts      Boolean  @default(true)
  status_changes      Boolean  @default(true)
  marketing_emails    Boolean  @default(false)
  weekly_digest       Boolean  @default(true)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
  user                User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model JobIndustry {
  id            Int               @id @default(autoincrement())
  industry_name String            @unique
  employers     EmployerProfile[]
  jobs          JobPost[]
}

model EmploymentType {
  id        Int       @id @default(autoincrement())
  type_name String    @unique
  jobs      JobPost[]
}

model JobPostStatus {
  id          Int       @id @default(autoincrement())
  status_name String    @unique
  jobs        JobPost[]
}

model JobApplicationStatus {
  id           Int              @id @default(autoincrement())
  status_name  String           @unique
  applications JobApplication[]
}

model JobPost {
  id                 String           @id @default(uuid())
  title              String
  description        String
  requirements       String?
  benefits           String?
  employer_id        String
  industry_id        Int
  employment_type_id Int
  salary_min         Decimal?         @db.Decimal(10, 2)
  salary_max         Decimal?         @db.Decimal(10, 2)
  salary_range       String?
  location           String
  is_remote          Boolean          @default(false)
  status_id          Int
  views_count        Int              @default(0)
  applications_count Int              @default(0)
  created_at         DateTime         @default(now())
  updated_at         DateTime         @updatedAt
  company_name       String?
  managed_company_id String?
  applications       JobApplication[]
  bookmarks          JobBookmark[]
  employer           EmployerProfile  @relation(fields: [employer_id], references: [id], onDelete: Cascade)
  employment_type    EmploymentType   @relation(fields: [employment_type_id], references: [id])
  industry           JobIndustry      @relation(fields: [industry_id], references: [id])
  managed_company    ManagedCompany?  @relation(fields: [managed_company_id], references: [id])
  status             JobPostStatus    @relation(fields: [status_id], references: [id])

  @@index([employer_id])
  @@index([status_id])
  @@index([industry_id])
  @@index([employment_type_id])
  @@index([created_at])
  @@index([company_name])
  @@index([managed_company_id])
}

model JobApplication {
  id             String               @id @default(uuid())
  job_id         String
  seeker_id      String
  resume_url     String?
  cover_letter   String?
  status_id      Int
  employer_notes String?
  applied_at     DateTime             @default(now())
  updated_at     DateTime             @updatedAt
  job            JobPost              @relation(fields: [job_id], references: [id], onDelete: Cascade)
  seeker         JobSeekerProfile     @relation(fields: [seeker_id], references: [id], onDelete: Cascade)
  status         JobApplicationStatus @relation(fields: [status_id], references: [id])
  notes          JobApplicationNote[]

  @@unique([job_id, seeker_id])
  @@index([job_id])
  @@index([seeker_id])
  @@index([status_id])
}

model JobApplicationNote {
  id             Int             @id @default(autoincrement())
  application_id String
  employer_id    String
  note_text      String
  created_at     DateTime        @default(now())
  application    JobApplication  @relation(fields: [application_id], references: [id], onDelete: Cascade)
  employer       EmployerProfile @relation(fields: [employer_id], references: [id])

  @@index([application_id])
}

model JobBookmark {
  id         Int              @id @default(autoincrement())
  seeker_id  String
  job_id     String
  created_at DateTime         @default(now())
  job        JobPost          @relation(fields: [job_id], references: [id], onDelete: Cascade)
  seeker     JobSeekerProfile @relation(fields: [seeker_id], references: [id], onDelete: Cascade)

  @@unique([seeker_id, job_id])
  @@index([seeker_id])
  @@index([job_id])
}

model Notification {
  id         Int      @id @default(autoincrement())
  user_id    String
  title      String
  message    String
  type       String
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())
  metadata   Json?
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([is_read])
  @@index([created_at])
}

model SearchLog {
  id            Int      @id @default(autoincrement())
  user_id       String?
  search_term   String
  filters       Json?
  results_count Int      @default(0)
  created_at    DateTime @default(now())
  user          User?    @relation(fields: [user_id], references: [id])

  @@index([created_at])
  @@index([search_term])
}

model Backup {
  id         String   @id @default(uuid())
  name       String
  type       String   @default("full")
  size       String
  size_bytes Int      @default(0)
  status     String   @default("completed")
  location   String?
  created_by String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([created_at])
  @@index([status])
}