generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========== USER MANAGEMENT ==========

model UserType {
  id         Int      @id @default(autoincrement())
  type_name  String   @unique
  users      User[]
  created_at DateTime @default(now())
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String // Hashed
  user_type_id Int
  is_active    Boolean  @default(true)
  full_name    String?  // ← ADD THIS
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  user_type               UserType                @relation(fields: [user_type_id], references: [id])
  seeker_profile          JobSeekerProfile?
  employer_profile        EmployerProfile?
  notifications           Notification[]
  search_logs             SearchLog[]
  notification_preference NotificationPreference?
  AuditLog                AuditLog[]

  @@index([email])
  @@index([user_type_id])
}

// ========== SYSTEM SETTINGS MODEL ==========

model SystemSetting {
  id                          Int      @id @default(autoincrement())
  site_name                   String   @default("Job Portal")
  site_description            String   @default("Connect job seekers with employers")
  contact_email               String   @default("admin@jobportal.com")
  enable_registration         Boolean  @default(true)
  require_email_verification  Boolean  @default(true)
  max_job_posts_per_employer  Int      @default(50)
  max_applications_per_seeker Int      @default(100)
  job_expiry_days             Int      @default(30)
  maintenance_mode            Boolean  @default(false)
  allowed_file_types          String[] @default(["pdf", "doc", "docx", "txt"])
  max_file_size_mb            Int      @default(5)
  created_at                  DateTime @default(now())
  updated_at                  DateTime @updatedAt
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  admin_id    String
  action      String
  target_type String
  target_id   String
  details     Json?
  ip_address  String?
  created_at  DateTime @default(now())

  admin User @relation(fields: [admin_id], references: [id])
}

// ========== PROFILES ==========

model JobSeekerProfile {
  id         String   @id @default(uuid())
  full_name  String
  phone      String?
  resume_url String?
  skills     String[] // Array of skills
  experience String? // Years of experience
  education  String? // JSON or text
  location   String?
  cover_image  String?
   avatar       String?
   bio          String?  // ← ADD THIS
  title        String?  // ← ADD THIS
  linkedin_url String?  // ← ADD THIS
  github_url   String?  // ← ADD THIS
  portfolio_url String? // ← ADD THIS
  availability String?  // ← ADD THIS
   preferences  JobSeekerPreference?
  user_id    String   @unique

  user         User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  applications JobApplication[]
  bookmarks    JobBookmark[]

  @@index([user_id])
}



// ========== JOB SEEKER PREFERENCES ==========

model JobSeekerPreference {
  id                       String   @id @default(uuid())
  seeker_id                String   @unique
  job_alerts_enabled       Boolean  @default(true)
  email_notifications      Boolean  @default(true)
  push_notifications       Boolean  @default(false)
  profile_visibility       String   @default("public") // public, private, employers_only
  preferred_job_types      String[] @default([])
  preferred_locations      String[] @default([])
  preferred_industries     Int[]    @default([])
  min_salary               Int?
  max_salary               Int?
  experience_level         String   @default("entry") // entry, mid, senior, executive
  notification_frequency   String   @default("instant") // instant, daily, weekly
  resume_visibility        Boolean  @default(true)
  allow_employer_contact   Boolean  @default(true)
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt

  seeker JobSeekerProfile @relation(fields: [seeker_id], references: [id], onDelete: Cascade)

  @@index([seeker_id])
}
model EmployerProfile {
  id                  String  @id @default(uuid())
  company_name        String
  company_description String?
  website             String?
  logo_url            String?
  industry_id         Int
  company_size        String?
  location            String?
  
  cover_image    String?   // ← Add this
  user_id             String  @unique

  user     User                 @relation(fields: [user_id], references: [id], onDelete: Cascade)
  industry JobIndustry          @relation(fields: [industry_id], references: [id])
  jobs     JobPost[]
  notes    JobApplicationNote[]

  @@index([user_id])
  @@index([industry_id])
}

model NotificationPreference {
  id                  Int      @id @default(autoincrement())
  user_id             String   @unique
  email_notifications Boolean  @default(true)
  push_notifications  Boolean  @default(true)
  application_updates Boolean  @default(true)
  new_job_alerts      Boolean  @default(true)
  status_changes      Boolean  @default(true)
  marketing_emails    Boolean  @default(false)
  weekly_digest       Boolean  @default(true)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

// ========== LOOKUP TABLES ==========

model JobIndustry {
  id            Int               @id @default(autoincrement())
  industry_name String            @unique
  employers     EmployerProfile[]
  jobs          JobPost[]
}

model EmploymentType {
  id        Int       @id @default(autoincrement())
  type_name String    @unique // Full-time, Part-time, Remote, Hybrid, Contract
  jobs      JobPost[]
}

model JobPostStatus {
  id          Int       @id @default(autoincrement())
  status_name String    @unique // Open, Closed, Draft, Archived
  jobs        JobPost[]
}

model JobApplicationStatus {
  id           Int              @id @default(autoincrement())
  status_name  String           @unique // Pending, Reviewed, Shortlisted, Interview, Accepted, Rejected
  applications JobApplication[]
}

// ========== CORE BUSINESS TABLES ==========

model JobPost {
  id                 String   @id @default(uuid())
  title              String
  description        String   @db.Text
  requirements       String?  @db.Text
  benefits           String?
  employer_id        String
  industry_id        Int
  employment_type_id Int
  salary_min         Decimal? @db.Decimal(10, 2)
  salary_max         Decimal? @db.Decimal(10, 2)
  salary_range       String? // For display: "$50k - $70k"
  location           String
  is_remote          Boolean  @default(false)
  status_id          Int
  views_count        Int      @default(0)
  applications_count Int      @default(0)
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  employer        EmployerProfile  @relation(fields: [employer_id], references: [id], onDelete: Cascade)
  industry        JobIndustry      @relation(fields: [industry_id], references: [id])
  employment_type EmploymentType   @relation(fields: [employment_type_id], references: [id])
  status          JobPostStatus    @relation(fields: [status_id], references: [id])
  applications    JobApplication[]
  bookmarks       JobBookmark[]

  @@index([employer_id])
  @@index([status_id])
  @@index([industry_id])
  @@index([employment_type_id])
  @@index([created_at])
}

model JobApplication {
  id             String   @id @default(uuid())
  job_id         String
  seeker_id      String
  resume_url     String? // URL to resume file
  cover_letter   String?  @db.Text
  status_id      Int
  employer_notes String?  @db.Text
  applied_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  job    JobPost              @relation(fields: [job_id], references: [id], onDelete: Cascade)
  seeker JobSeekerProfile     @relation(fields: [seeker_id], references: [id], onDelete: Cascade)
  status JobApplicationStatus @relation(fields: [status_id], references: [id])
  notes  JobApplicationNote[]

  @@unique([job_id, seeker_id]) // Prevent duplicate applications
  @@index([job_id])
  @@index([seeker_id])
  @@index([status_id])
}

model JobApplicationNote {
  id             Int      @id @default(autoincrement())
  application_id String
  employer_id    String
  note_text      String   @db.Text
  created_at     DateTime @default(now())

  application JobApplication  @relation(fields: [application_id], references: [id], onDelete: Cascade)
  employer    EmployerProfile @relation(fields: [employer_id], references: [id])

  @@index([application_id])
}

model JobBookmark {
  id         Int      @id @default(autoincrement())
  seeker_id  String
  job_id     String
  created_at DateTime @default(now())

  seeker JobSeekerProfile @relation(fields: [seeker_id], references: [id], onDelete: Cascade)
  job    JobPost          @relation(fields: [job_id], references: [id], onDelete: Cascade)

  @@unique([seeker_id, job_id])
  @@index([seeker_id])
  @@index([job_id])
}

// ========== NOTIFICATIONS ==========

model Notification {
  id         Int      @id @default(autoincrement())
  user_id    String
  title      String
  message    String   @db.Text
  type       String // application_update, new_job, status_change, etc.
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())
  metadata   Json?    // Optional additional data

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([is_read])
  @@index([created_at])
}

// ========== ANALYTICS ==========

model SearchLog {
  id            Int      @id @default(autoincrement())
  user_id       String?
  search_term   String
  filters       Json? // Store filter criteria as JSON
  results_count Int      @default(0)
  created_at    DateTime @default(now())

  user User? @relation(fields: [user_id], references: [id])

  @@index([created_at])
  @@index([search_term])
}